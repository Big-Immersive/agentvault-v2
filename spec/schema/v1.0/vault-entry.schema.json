{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentvault.dev/schema/v1.0/vault-entry.schema.json",
  "title": "ACSS Vault Entry",
  "description": "A credential stored in the encrypted vault. Part of the Agent Credential Sandboxing Standard (ACSS) v1.0.",
  "type": "object",
  "required": ["key", "value", "addedAt"],
  "additionalProperties": false,
  "properties": {
    "key": {
      "type": "string",
      "minLength": 1,
      "description": "The credential name (environment variable name)."
    },
    "value": {
      "type": "string",
      "description": "The credential value (plaintext when decrypted)."
    },
    "addedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the entry was added or last updated."
    }
  }
}
